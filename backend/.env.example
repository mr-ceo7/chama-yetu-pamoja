# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/tambuatips_com

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
