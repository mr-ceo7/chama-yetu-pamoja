ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── API-Football Keys (comma separated) ─────────────────────
API_FOOTBALL_KEYS=key1,key2,key3

# ─── Payments ─────────────────────────────────────────────────
